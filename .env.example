# PostgreSQL
POSTGRES_DB=fcg3
POSTGRES_USER=fcg3
POSTGRES_PASSWORD=changeme

# Database URL (FastAPI + MCP use asyncpg; LangChain uses psycopg)
DATABASE_URL=postgresql+asyncpg://fcg3:changeme@postgres:5432/fcg3

# Alembic (sync driver for migrations)
ALEMBIC_DATABASE_URL=postgresql://fcg3:changeme@postgres:5432/fcg3

# MCP Service Token (internal auth between MCP server and FastAPI)
MCP_SERVICE_TOKEN=changeme-generate-a-real-token

# WhatsApp Business Cloud API
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token
WHATSAPP_APP_SECRET=your-whatsapp-app-secret

# Email OTP (Resend)
RESEND_API_KEY=your-resend-api-key

# JWT
JWT_SECRET=generate-a-32-char-minimum-secret-here

# LLM Provider (openai | gemini)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key

# Google (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key

# Firebase Cloud Messaging (optional for Phase 1)
FCM_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# FastAPI internal URL (for MCP server internal calls)
FASTAPI_URL=http://fastapi-app:8000
