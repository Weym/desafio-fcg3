# Copy this file to .env and fill in real values. NEVER commit .env.
# Keep secrets only in local env files or your secret manager; never paste them into source, tickets, or chat logs.

# ============================================
# PostgreSQL
# ============================================
# PostgreSQL database name shared by all services.
POSTGRES_DB=fcg3
# PostgreSQL username for local development.
POSTGRES_USER=fcg3
# PostgreSQL password placeholder - change in real environments.
POSTGRES_PASSWORD=change_me_in_production

# ============================================
# FastAPI App (backend)
# ============================================
# Async runtime database URL for FastAPI (must use asyncpg).
DATABASE_URL=postgresql+asyncpg://fcg3:change_me_in_production@postgres:5432/fcg3
# Sync migration database URL for Alembic (auto-derived if omitted by config).
ALEMBIC_DATABASE_URL=postgresql://fcg3:change_me_in_production@postgres:5432/fcg3

# JWT signing secret - generate a unique value per environment, e.g. `openssl rand -hex 32`.
JWT_SECRET=replace_with_a_unique_32_plus_char_secret
# JWT algorithm for auth tokens.
JWT_ALGORITHM=HS256
# JWT expiration window in hours.
JWT_EXPIRATION_HOURS=24

# Internal service token shared between MCP Server and FastAPI - generate a unique value per environment.
MCP_SERVICE_TOKEN=replace_with_a_unique_shared_service_token

# WhatsApp Business Cloud API permanent access token placeholder.
WHATSAPP_TOKEN=replace_with_whatsapp_business_api_token
# WhatsApp Business phone number ID placeholder.
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
# Custom verification token used by Meta webhook challenge.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace_with_webhook_verify_token
# WhatsApp app secret used for webhook signature validation.
WHATSAPP_APP_SECRET=replace_with_whatsapp_app_secret

# Resend API key placeholder - keep the real key only outside version control.
RESEND_API_KEY=replace_with_resend_api_key

# Optional Firebase service account JSON path for push notifications.
FCM_CREDENTIALS_PATH=/path/to/firebase-service-account.json

# ============================================
# LangChain AI Service
# ============================================
# Psycopg database URL for LangChain and PGVector access.
DATABASE_URL_AI=postgresql+psycopg://fcg3:change_me_in_production@postgres:5432/fcg3

# LLM provider selector (openai or gemini).
LLM_PROVIDER=openai
# Default chat model name used by the selected provider.
LLM_MODEL=gpt-4o-mini
# OpenAI API key placeholder - required when LLM_PROVIDER=openai.
OPENAI_API_KEY=replace_with_openai_api_key
# Gemini API key placeholder - required when LLM_PROVIDER=gemini.
GEMINI_API_KEY=replace_with_gemini_api_key

# ============================================
# MCP Server
# ============================================
# Async runtime database URL for MCP Server logging/runtime access.
DATABASE_URL_MCP=postgresql+asyncpg://fcg3:change_me_in_production@postgres:5432/fcg3
# Internal FastAPI base URL reached from the MCP container.
FASTAPI_URL=http://fastapi-app:8000
# Same internal service token used by FastAPI above.
MCP_SERVICE_TOKEN=replace_with_a_unique_shared_service_token
